@player Starting Script

# Gate 0

@for Block i in flh_ss::get_placerange(Block(2972, 68, 6942, "Zero"), Block(2974, 71, 6942, "Zero"))
        @bypass /script import walk {{i.getX()}} {{i.getY()}} {{i.getZ()}} Zero https://paste.minr.org/zixifuwico.coffeescript
@done
@define Block centre_block = Block(2973, 68, 6942, "Zero")
@using hoyu_scripts
@if placed_gates.length() == 0
	@var placed_gates.append(centre_block)
@elseif placed_gates.contains(centre_block) == false
        @var placed_gates.append(centre_block)
@fi
@define Int[] keytemp = Int[]
@for Int i in list::range(0, placed_gates.length())
        @var keytemp.append(i)
@done
@var redmaze_key = keytemp

