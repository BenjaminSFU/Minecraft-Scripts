@using flh_ss
# Gate messages
@for Block i in get_placerange(Block(-13265, 111, -9818), Block(-13263, 111, -9818))
    @bypass /s i w {{i.getX()}} {{i.getY()}} {{i.getZ()}} Theta https://paste.minr.org/tohihakope
@done
