# Placing gate scritps
@using flh_ss
# Gate messages
@for Block i in get_placerange(Block(-13265, 111, -9818, "Theta"), Block(-13263, 111, -9818, "Theta"))
    @bypass /s i w {{i.getX()}} {{i.getY()}} {{i.getZ()}} Theta https://paste.minr.org/tohihakope
@done
@for Block i in get_placerange(Block(-13265, 111, -9827, "Theta"), Block(-13263, 111, -9827, "Theta"))
    @bypass /s i w {{i.getX()}} {{i.getY()}} {{i.getZ()}} Theta https://paste.minr.org/tohihakope
@done
# Gate teleports
@for Block i in get_placerange(Block(-13265, 111, -9824, "Theta"), Block(-13263, 111, -9824, "Theta"))
    @bypass /s i w {{i.getX()}} {{i.getY()}} {{i.getZ()}} Theta https://paste.minr.org/uverajuziy
@done
@for Block i in get_placerange(Block(-13265, 111, -9821, "Theta"), Block(-13263, 111, -9821, "Theta"))
