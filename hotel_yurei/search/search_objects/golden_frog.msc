@fast
@using hoyu_scripts
@if search_holding.contains("golden_frog") != true
    @player &eYou lift the golden frog from its pedestal, half expecting a boulder to come crashing down upon you. Thankfully, the temple remains silent.
    @var search_holding.append("golden_frog")
@else
    @player &eYou're already holding the golden frog, so there's no point in grabbing it again.
@fi
@delay 10s

