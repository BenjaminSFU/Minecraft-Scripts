@fast
@using hoyu_scripts
@if search_holding.contains("coffin_sculpture") != true
    @player &eYou tear the sculpted head from the coffin. Its eyes seem to condemn you as you stow it away.
    @var search_holding.append("coffin_sculpture")
@else
    @player &eYou're already holding the head, so there's no point in grabbing it again.
@fi
@delay 10s

