@using flh_ss
@player Starting Script
@for Block i in get_placerange(Block(-12283, 284, -9834, "Theta"), Block(-12283, 292, -9837, "Theta"))
	@bypass /script import walk {{i.getX()}} {{i.getY()}} {{i.getZ()}} Theta https://paste.minr.org/buwoheteho.coffeescript
@done
@for Block i in get_placerange(Block(-12541, 284, -9702, "Theta"), Block(-12541, 292, -9705, "Theta"))
	@bypass /script import walk {{i.getX()}} {{i.getY()}} {{i.getZ()}} Theta https://paste.minr.org/anisaxetij.coffeescript
@done

