@using flh_ss
@player Starting Script
@for Block i in get_placerange(Block(3008, 69, 6955, "Zero"), Block(3005, 77, 6955, "Zero"))
	@bypass /script import walk {{i.getX()}} {{i.getY()}} {{i.getZ()}} Zero https://paste.minr.org/ekurukojum.coffeescript
	@player Placing tp_player at {{i.getX()}} {{i.getY()}} {{i.getZ()}}
@done